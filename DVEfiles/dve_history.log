gui_list_select -id Data.1 -selected  { top_test.dut.clock   }
gui_open_window Wave
gui_list_add -id Wave.1 -from Data.1 { top_test.dut.clock } -insertionbar
gui_list_expand -id  Hier.1   top_test.dut
