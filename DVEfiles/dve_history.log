gui_list_add -id Wave.1 -from Data.1 { top_test.dut.cl_L } -insertionbar
gui_list_select -id Data.1 -selected  { top_test.dut.ld_L   }
gui_list_add -id Wave.1 -from Data.1 { top_test.dut.ld_L } -insertionbar
gui_list_select -id Data.1 -selected  { {top_test.dut.addOut[15:0]}   }
gui_list_add -id Wave.1 -from Data.1 { {top_test.dut.addOut[15:0]} } -insertionbar
gui_list_select -id Data.1 -selected  { {top_test.dut.sum[15:0]}   }
gui_list_add -id Wave.1 -from Data.1 { {top_test.dut.sum[15:0]} } -insertionbar
