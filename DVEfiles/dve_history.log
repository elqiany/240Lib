gui_list_select -id Data.1 -selected  { top_test.dut.c1.ns   }
gui_list_add -id Wave.1 -from Data.1 { {top_test.dut.c1.ns[2:0]} } -insertionbar
gui_list_select -id Hier.1 -current_item_name top_test.dut -current_item_type Scope  -selected  { top_test.dut   }
